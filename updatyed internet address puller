function fetchOrderTrackerDataByAddress() {
  var ss = SpreadsheetApp.getActiveSpreadsheet();
  
  var telusSheet = ss.getSheetByName('telus data');
  var orderSheet = ss.getSheetByName('order tracker data');
  
  var telusData = telusSheet.getDataRange().getValues();
  var orderData = orderSheet.getDataRange().getValues();
  
  var addressCol = 14; // Column O
  
  var orderMap = {};
  
  for (var i = 1; i < orderData.length; i++) {
    var orderRow = orderData[i];
    var rawOrderAddress = orderRow[addressCol];
    if (!rawOrderAddress || rawOrderAddress === '') continue;
    
    var cleanedOrderAddress = cleanAddressForMatching(rawOrderAddress);
    
    if (!orderMap[cleanedOrderAddress]) {
      var fullRowData = [];
      for (var j = 0; j < orderRow.length; j++) {
        fullRowData.push(orderRow[j] !== undefined ? orderRow[j] : '');
      }
      orderMap[cleanedOrderAddress] = fullRowData;
    }
  }
  
  var matchesFound = 0;
  var rowsUpdated = 0;
  
  for (var i = 1; i < telusData.length; i++) {
    var telusRow = telusData[i];
    var rawTelusAddress = telusRow[addressCol];
    
    if (!rawTelusAddress || rawTelusAddress === '') continue;
    
    var cleanedTelusAddress = cleanAddressForMatching(rawTelusAddress);
    var matchedOrderData = orderMap[cleanedTelusAddress];
    
    if (matchedOrderData) {
      matchesFound++;
      var startColumn = 20;
      
      for (var j = 0; j < matchedOrderData.length; j++) {
        var targetColumn = startColumn + j;
        telusSheet.getRange(i + 1, targetColumn + 1).setValue(matchedOrderData[j]);
      }
      rowsUpdated++;
    }
  }
  
  SpreadsheetApp.getUi().alert('Address matching complete!\n\n' +
    'Total unique addresses in order tracker: ' + Object.keys(orderMap).length + '\n' +
    'Matches found in telus data: ' + matchesFound + '\n' +
    'Rows updated in telus data: ' + rowsUpdated);
}


function cleanAddressForMatching(address) {
  if (!address || address === '') return '';
  
  // Uppercase and strip everything after the first comma (city, province, postal)
  var cleaned = address.toString().trim().toUpperCase();
  cleaned = cleaned.split(',')[0].trim();
  
  // --- Step 1: Strip unit/suite prefixes with explicit separator ---
  // Handles: "1 - 38 COULSON", "PH8 - 24 SEELEY", "2 # 38 COULSON"
  cleaned = cleaned.replace(/^[A-Z0-9]+ - /, '');
  cleaned = cleaned.replace(/^[A-Z0-9]+#\s*/, '');
  
  // --- Step 2: Strip "digit-digit" dash format (no spaces) ---
  // Handles: "3-38 COULSON" → "38 COULSON"
  cleaned = cleaned.replace(/^\d+-(\d)/, '$1');

  // --- Step 3: Strip alphanumeric unit prefix before a number ---
  // Handles: "B11 24 SEELEY" → "24 SEELEY"
  // Matches a leading token that starts with a letter (e.g. B11, PH8, APT3)
  cleaned = cleaned.replace(/^[A-Z]+\d+\s+(\d)/, '$1');

  // --- Step 4: Strip plain numeric unit prefix before a larger/different number ---
  // Handles: "303 425 DUNDAS", "8 6902 WATERS", "17 1507 35 AVE",
  //          "11 16 GEORGE", "32 6263 LUND", "3 38 COULSON"
  // Logic: if the first token is a number AND the second token is also a number,
  // the first is a unit — drop it.
  var parts = cleaned.split(/\s+/);
  if (parts.length >= 3 && /^\d+$/.test(parts[0]) && /^\d+$/.test(parts[1])) {
    // First two tokens are both numbers → first is unit, drop it
    parts.shift();
    cleaned = parts.join(' ');
  }

  // --- Step 5: Rebuild to "streetNumber streetName" (first two tokens only) ---
  parts = cleaned.split(/\s+/);
  if (parts.length >= 2) {
    cleaned = parts[0] + ' ' + parts[1];
  }

  // --- Step 6: Strip common street type suffixes ---
  var suffixes = [
    'STREET', 'ST', 'DRIVE', 'DR', 'CIRCLE', 'CIR',
    'AVENUE', 'AVE', 'ROAD', 'RD', 'COURT', 'CT',
    'CRESCENT', 'CRES', 'LANE', 'LN', 'BOULEVARD', 'BLVD',
    'PLACE', 'PL', 'WAY', 'TERRACE', 'TER', 'TRAIL', 'TRL',
    'CLOSE', 'GATE', 'GROVE', 'HEIGHTS', 'HTS', 'PARK', 'PATH'
  ];
  
  var suffixRegex = new RegExp('\\s+(' + suffixes.join('|') + ')$', 'i');
  cleaned = cleaned.replace(suffixRegex, '');
  
  return cleaned.trim();
}


